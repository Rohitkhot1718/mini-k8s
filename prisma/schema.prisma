generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  PENDING
  WAITING
  RUNNABLE
  RUNNING
  STOPPED
  FAILED
}

model JobContainers {
  id          String   @id @default(uuid())
  image       String
  status      Status   @default(PENDING)
  containerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}
